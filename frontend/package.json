{
  "name": "royal-match-poker",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:mobile": "vite build --mode capacitor",
    "preview": "vite preview",
    "cap:sync": "npm run build:mobile && npx cap sync",
    "cap:sync:android": "npm run build:mobile && npx cap sync android",
    "cap:sync:ios": "npm run build:mobile && npx cap sync ios",
    "cap:open": "npx cap open android",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:run": "npm run cap:sync:android && npx cap run android",
    "cap:run:android": "npm run cap:sync:android && npx cap run android",
    "cap:run:ios": "npm run cap:sync:ios && npx cap run ios",
    "icons:android": "node scripts/generate-android-icons.mjs"
  },
  "dependencies": {
    "@capacitor-community/admob": "^7.2.0",
    "@capacitor/app": "^7.1.2",
    "@capacitor/core": "^7.4.2",
    "@capacitor/push-notifications": "^7.0.7",
    "@tailwindcss/vite": "^4.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.4.2",
    "@capacitor/ios": "^7.6.8",
    "@capacitor/splash-screen": "^7.0.2",
    "@capacitor/status-bar": "^7.0.2",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "sharp": "^0.33.5",
    "typescript": "~5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^0.21.1"
  }
}
